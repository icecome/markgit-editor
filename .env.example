# MarkGit Editor 配置文件
# 复制此文件为 .env 并填入实际值

# ==================== 必需配置 ====================

# GitHub OAuth 配置（必需）
# 在 GitHub Developer Settings 中创建 OAuth App 获取
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitHub OAuth 权限范围
# repo: 完整的仓库访问权限
# workflow: GitHub Actions 工作流权限
GITHUB_SCOPE=repo,workflow

# ==================== 生产环境配置 ====================

# 生产环境标志（生产环境设置为 true，开发环境设置为 false）
PRODUCTION=true

# 服务端口
PORT=13131

# CORS 允许的来源（生产环境必需，多个用逗号分隔）
# 示例：https://your-domain.com,https://app.your-domain.com
CORS_ORIGINS=http://localhost:13131,http://127.0.0.1:13131

# ==================== 可选配置 ====================

# Redis 配置（生产环境推荐）
# 如果未设置 REDIS_URL，将使用内存存储
# 示例：redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0

# 会话配置
# SESSION_TIMEOUT_HOURS=1          # 会话超时时间（小时）
# MAX_CONCURRENT_SESSIONS=100      # 最大并发会话数

# Git 配置
# BLOG_BRANCH=main                 # 博客仓库分支
# GIT_OPERATION_TIMEOUT=120        # Git 操作超时（秒）
# GIT_CLONE_TIMEOUT=300            # Git 克隆超时（秒）

# Git 缓存路径（可选）
# 默认使用项目目录下的 blog_cache 文件夹
# Windows 示例：BLOG_CACHE_PATH=D:/markgit_cache
# Linux 示例：BLOG_CACHE_PATH=/var/cache/markgit
# BLOG_CACHE_PATH=./blog_cache

# 安全配置
# SSL_VERIFY=true                  # SSL 证书验证（生产环境建议开启）

# 文件配置
# MAX_FILE_CONTENT_SIZE=1048576    # 文件内容最大长度（字节，默认 1MB）
